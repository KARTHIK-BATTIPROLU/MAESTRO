# ─── MAESTRO Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in real values. .env is gitignored.

PORT=5000
NODE_ENV=development
AGENT_SERVICE_URL=http://localhost:8000
MONGODB_URI=your_mongodb_connection_string_here

# Comma-separated list of allowed origins (no trailing slash)
# In production, replace with your actual frontend URL(s)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Resilience (optional — defaults shown)
AGENT_TIMEOUT_MS=300000
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RECOVERY_TIMEOUT_MS=60000

# Rate limiting (optional — defaults shown)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
